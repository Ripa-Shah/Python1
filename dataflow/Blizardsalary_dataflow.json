{
	"name": "Blizardsalary_dataflow",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "SourceDataset_7x0",
						"type": "DatasetReference"
					},
					"name": "Blizzardsalarydataset"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DestinationDataset_7x0",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "sort1"
				},
				{
					"name": "timestamptodate"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id as string,",
				"          timestamp as string,",
				"          status as string,",
				"          current_title as string,",
				"          current_salary as string,",
				"          salary_type as string,",
				"          percent_incr as string,",
				"          other_info as string,",
				"          location as string,",
				"          performance_rating as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> Blizzardsalarydataset",
				"Blizzardsalarydataset sort(asc(ERROR_FUNCTION(''), true)) ~> sort1",
				"sort1 cast(output(",
				"          timestamp as date 'MM-dd-yyyy'",
				"     ),",
				"     errors: true) ~> timestamptodate",
				"Blizzardsalarydataset sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'document',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}