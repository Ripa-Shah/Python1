{
	"name": "flowlet11",
	"properties": {
		"type": "Flowlet",
		"typeProperties": {
			"sources": [],
			"sinks": [],
			"transformations": [
				{
					"name": "SalaryTypeSplit"
				},
				{
					"name": "HourlySalary"
				},
				{
					"name": "YearlySalary"
				},
				{
					"name": "combinesalary"
				},
				{
					"name": "select1"
				},
				{
					"name": "Blizzardsalarydataset"
				}
			],
			"scriptLines": [
				"input(output(",
				"          id as string,",
				"          timestamp as string,",
				"          status as string,",
				"          current_title as string,",
				"          current_salary as string,",
				"          salary_type as string,",
				"          percent_incr as string,",
				"          other_info as string,",
				"          location as string,",
				"          performance_rating as string",
				"     ),",
				"     order: 0,",
				"     allowSchemaDrift: true) ~> Blizzardsalarydataset",
				"Blizzardsalarydataset split(lower(trim(salary_type)) == 'year',",
				"     ERROR_FUNCTION(''),",
				"     disjoint: false) ~> SalaryTypeSplit@(yearStream, hourStream)",
				"SalaryTypeSplit@hourStream derive(other_info = ERROR_FUNCTION('')) ~> HourlySalary",
				"SalaryTypeSplit@yearStream derive(salary_type_hour = salary_type == 'hour',",
				"          salary_type_year = salary_type == 'year') ~> YearlySalary",
				"HourlySalary, YearlySalary, Blizzardsalarydataset union(byName: true)~> combinesalary",
				"combinesalary select(mapColumn(",
				"          id,",
				"          timestamp,",
				"          status,",
				"          current_title,",
				"          current_salary,",
				"          salary_type,",
				"          percent_incr,",
				"          other_info,",
				"          location,",
				"          performance_rating",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1"
			]
		}
	}
}