{
	"name": "flowlet11",
	"properties": {
		"type": "Flowlet",
		"typeProperties": {
			"sources": [],
			"sinks": [],
			"transformations": [
				{
					"name": "SalaryTypeSplit"
				},
				{
					"name": "Blizzardsalarydataset"
				}
			],
			"scriptLines": [
				"input(output(",
				"          id as string,",
				"          timestamp as string,",
				"          status as string,",
				"          current_title as string,",
				"          current_salary as string,",
				"          salary_type as string,",
				"          percent_incr as string,",
				"          other_info as string,",
				"          location as string,",
				"          performance_rating as string",
				"     ),",
				"     order: 0,",
				"     allowSchemaDrift: true) ~> Blizzardsalarydataset",
				"Blizzardsalarydataset split(lower(trim(salary_type)) == 'year',",
				"     ERROR_FUNCTION(''),",
				"     disjoint: false) ~> SalaryTypeSplit@(yearStream, hourStream)"
			]
		}
	}
}