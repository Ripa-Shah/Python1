{
	"name": "Blizzard_salary_flowlet",
	"properties": {
		"type": "Flowlet",
		"typeProperties": {
			"sources": [],
			"sinks": [],
			"transformations": [
				{
					"name": "SalaryTypeSplit"
				},
				{
					"name": "HourlySalary"
				},
				{
					"name": "YearlySalary"
				},
				{
					"name": "combinesalary"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "BlizzardSalaryJSON"
				},
				{
					"name": "Blizzardsalarydataset"
				},
				{
					"name": "output1"
				}
			],
			"scriptLines": [
				"input(output(",
				"          id as string,",
				"          timestamp as string,",
				"          status as string,",
				"          current_title as string,",
				"          current_salary as string,",
				"          salary_type as string,",
				"          percent_incr as string,",
				"          other_info as string,",
				"          location as string,",
				"          performance_rating as string",
				"     ),",
				"     order: 0,",
				"     allowSchemaDrift: true) ~> Blizzardsalarydataset",
				"Blizzardsalarydataset split(lower(trim(salary_type)) == 'year',",
				"     lower(trim(salary_type)) == 'hour',",
				"     disjoint: false) ~> SalaryTypeSplit@(yearStream, hourStream)",
				"SalaryTypeSplit@hourStream derive(salary_type_hour = salary_type == 'hour') ~> HourlySalary",
				"SalaryTypeSplit@yearStream derive(salary_type_year = salary_type == 'year') ~> YearlySalary",
				"YearlySalary, HourlySalary union(byName: true)~> combinesalary",
				"combinesalary derive(percent_incr = iif(toDouble(percent_incr) > 0, toDouble(percent_incr), toDouble(0.0))) ~> derivedColumn1",
				"derivedColumn1 parse(format: 'json',",
				"     documentForm: 'documentPerLine') ~> BlizzardSalaryJSON",
				"BlizzardSalaryJSON output() ~> output1"
			]
		}
	}
}